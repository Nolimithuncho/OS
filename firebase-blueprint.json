{
  "entities": {
    "Section": {
      "title": "Section",
      "description": "Website structural sections metadata",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["id", "name"]
    },
    "Content": {
      "title": "Content",
      "description": "Uploaded content details under different sections",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "section": {
          "type": "string",
          "enum": ["about", "canon", "documents", "gallery"]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "fileUrl": {
          "type": "string"
        },
        "fileType": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string"
        },
        "link": {
          "type": "string"
        },
        "order": {
          "type": "integer"
        },
        "status": {
          "type": "string",
          "enum": ["published", "draft"]
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": ["section", "title", "status", "order"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "Alert subscriber profiles",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "interests": {
          "type": "array"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["code", "name", "email"]
    },
    "MentorshipApp": {
      "title": "MentorshipApp",
      "description": "Fellowship applications",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "discipline": {
          "type": "string"
        },
        "proposal": {
          "type": "string"
        },
        "focus": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["PENDING ADMISSION REVIEW", "APPROVED", "DECLINED"]
        },
        "userId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["id", "name", "email", "discipline", "proposal", "focus", "status"]
    },
    "DecisionResponse": {
      "title": "DecisionResponse",
      "description": "Admin decision records on fellowship applications",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "appId": {
          "type": "string"
        },
        "applicantName": {
          "type": "string"
        },
        "applicantEmail": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["APPROVED", "DECLINED"]
        },
        "feedback": {
          "type": "string"
        },
        "respondedAt": {
          "type": "string"
        },
        "respondedBy": {
          "type": "string"
        }
      },
      "required": ["id", "appId", "applicantName", "applicantEmail", "status", "feedback", "respondedAt", "respondedBy"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comments on policy essays",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "essayId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        }
      },
      "required": ["essayId", "name", "text", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Authorized Admin Email Profiles",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "addedAt": {
          "type": "string"
        }
      },
      "required": ["email"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "Administrator login credentials with email and password",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "addedAt": {
          "type": "string"
        }
      },
      "required": ["name", "email", "password"]
    },
    "AdminPassphrase": {
      "title": "AdminPassphrase",
      "description": "Fallback entry console passphrase",
      "type": "object",
      "properties": {
        "passphrase": {
          "type": "string"
        }
      },
      "required": ["passphrase"]
    }
  },
  "firestore": {
    "sections/{sectionId}": {
      "schema": "Section",
      "description": "Section mapping definitions"
    },
    "content/{contentId}": {
      "schema": "Content",
      "description": "Aggregated content files and descriptions"
    },
    "subscribers/{email}": {
      "schema": "Subscriber",
      "description": "Registered subscriber profiles"
    },
    "mentorship/{appId}": {
      "schema": "MentorshipApp",
      "description": "Fellowship admission dossiers"
    },
    "responses/{responseId}": {
      "schema": "DecisionResponse",
      "description": "Logged admin response feedback and outcomes"
    },
    "comments/{commentId}": {
      "schema": "Comment",
      "description": "Durable reader feedback comments"
    },
    "admins/{email}": {
      "schema": "Admin",
      "description": "Authorized administrator emails"
    },
    "admin_users/{email}": {
      "schema": "AdminUser",
      "description": "Durable credentials for administrator profiles with password login"
    },
    "config/{documentId}": {
      "schema": "AdminPassphrase",
      "description": "App configurations such as entry passphrase"
    }
  }
}
